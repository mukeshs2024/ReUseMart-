{
  "name": "reusemart-backend",
  "version": "1.0.0",
  "description": "ReUse Mart API - Production Marketplace Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "test:integration": "vitest run test/integration"
  },
  "keywords": [],
  "author": "ReUse Mart",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "*",
    "@prisma/client": "*",
    "@supabase/supabase-js": "*",
    "bcryptjs": "*",
    "dotenv": "*",
    "express": "*",
    "jsonwebtoken": "*",
    "pg": "*",
    "socket.io": "^4.8.1",
    "zod": "*"
  },
  "devDependencies": {
    "@types/bcryptjs": "*",
    "@types/express": "*",
    "@types/jsonwebtoken": "*",
    "@types/node": "*",
    "@types/pg": "*",
    "@types/supertest": "^7.2.0",
    "nodemon": "*",
    "prisma": "*",
    "supertest": "^7.2.2",
    "tsx": "*",
    "typescript": "*",
    "vitest": "^4.1.3"
  }
}
